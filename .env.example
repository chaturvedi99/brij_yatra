# API (apps/api)
DATABASE_URL=postgres://brijyatra:brijyatra@127.0.0.1:5433/brijyatra
REDIS_URL=redis://127.0.0.1:6380
HOST=0.0.0.0
PORT=8080
RUST_LOG=brijyatra_api=debug,tower_http=debug,sqlx=warn
FIREBASE_PROJECT_ID=your-firebase-project-id
# Set to 1 for local dev: accepts X-Dev-User-Id and X-Dev-Role headers (no Firebase)
DEV_BYPASS_AUTH=1
# Production: unset DEV_BYPASS_AUTH or set to 0; require Firebase ID tokens only.

# CORS: comma-separated origins; empty = allow any (dev). Production: https://your-app,https://admin.example
ALLOWED_ORIGINS=

# Global HTTP rate limit (approx requests/sec per IP). Unset or 0 = disabled.
RATE_LIMIT_PER_SECOND=

# Optional: API base URL for presigned upload stubs
PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Flutter (apps/mobile) — use platform-specific config or --dart-define
API_BASE_URL=http://127.0.0.1:8080
# Production release example:
# flutter build apk --release --dart-define=API_BASE_URL=https://your-api.up.railway.app --dart-define=USE_FIREBASE_AUTH=true

# Railway + Firebase: see docs/deploy-railway-firebase.md
